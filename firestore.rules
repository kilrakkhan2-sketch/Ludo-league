
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getRole() {
      // Use the new, reliable way to get roles from the auth token
      return request.auth.token.role;
    }
    
    function isAdmin() {
      return getRole() in ['superadmin', 'deposit_admin', 'withdrawal_admin', 'match_admin'];
    }

    function isSuperAdmin() {
      return getRole() == 'superadmin';
    }

    function isDepositAdmin() {
      return getRole() in ['superadmin', 'deposit_admin'];
    }
    
    function isWithdrawalAdmin() {
      return getRole() in ['superadmin', 'withdrawal_admin'];
    }

    function isMatchAdmin() {
      return getRole() in ['superadmin', 'match_admin'];
    }

    //----------------------------------------------------------------------
    // USER PROFILES
    //----------------------------------------------------------------------
    match /users/{userId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn();
      allow list: if isSuperAdmin(); // Only superadmins can list all users
      allow update: if isOwner(userId) || isSuperAdmin();
      allow delete: if false;

        // Sub-collections for user-specific data
        match /transactions/{transactionId} {
            allow read: if isOwner(userId) || isSuperAdmin();
            // Transactions should only be created by the backend (Cloud Functions).
            allow create: if false;
            // Transactions are immutable.
            allow update, delete: if false;
        }

        match /personal_notifications/{notificationId} {
          allow read, list, write: if isOwner(userId);
        }

        match /penalties/{penaltyId} {
          allow read, list: if isOwner(userId) || isSuperAdmin();
          allow create: if false; // Server only
        }
    }

    //----------------------------------------------------------------------
    // GLOBAL COLLECTIONS
    //----------------------------------------------------------------------

    // Transactions Collection Group - for admin overview
    match /{path=**}/transactions/{transactionId} {
      allow read, list: if isSuperAdmin();
    }
    
    // Deposit Requests
    match /deposit-requests/{requestId} {
      allow read: if isDepositAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow list: if isDepositAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isDepositAdmin();
      allow delete: if false;
    }

    // Withdrawal Requests
    match /withdrawal-requests/{withdrawalId} {
      allow read: if isWithdrawalAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow list: if isWithdrawalAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isWithdrawalAdmin();
      allow delete: if false;
    }
    
    // KYC Requests
    match /kyc-requests/{kycId} {
      allow read: if isSuperAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow list: if isSuperAdmin();
      allow create: if isSignedIn();
      allow update: if isSuperAdmin();
    }
    
    // UPI Accounts for payments
    match /upi-accounts/{accountId} {
       allow read, list: if isDepositAdmin();
       allow create, update, delete: if isSuperAdmin();
    }

    // Matches
    match /matches/{matchId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isMatchAdmin() || 
                      (isSignedIn() && request.auth.uid in resource.data.players) || // Any player can update
                      (isSignedIn() && resource.data.status == 'waiting'); // A new player can join
    
      match /results/{userId} {
        allow read, list: if isSignedIn();
        allow create, update: if request.auth.uid == userId; // Only the user can submit their own result
      }
      match /messages/{messageId} {
        allow read, list: if isSignedIn();
        allow create: if request.auth.uid in resource.data.players;
      }
    }

    // Tournaments
    match /tournaments/{tournamentId} {
        allow read, list: if true;
        allow create, update, delete: if isMatchAdmin();
    }
    
    // Settings documents
    match /settings/{docId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // Announcements
    match /announcements/{announcementId} {
      allow read: if true;
      allow create, update, delete: if isSuperAdmin();
    }
    
     // Admin Wallet Transactions for auditing
    match /admin-wallet-transactions/{transactionId} {
      allow read, list: if isSuperAdmin();
      allow create: if false; // Server only
    }
  }
}
