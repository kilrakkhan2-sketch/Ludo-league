rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // This admin check is a placeholder. In a real app, use Firebase Auth custom claims.
    function isAdmin() {
      // return request.auth.token.admin == true;
      return isSignedIn(); // Placeholder: any signed-in user is an "admin" for now.
    }

    //----------------------------------------------------------------------
    // USER DATA
    //----------------------------------------------------------------------
    match /users/{userId} {
      // Admins can list all users. Users can only get their own profile.
      allow list: if isAdmin();
      allow get: if isOwner(userId) || isAdmin();

      // Anyone can create their own user profile upon signup.
      allow create: if isSignedIn();

      // Users can update their own profile. Admins can update any.
      allow update: if isOwner(userId) || isAdmin();

      // Users should not be able to delete their own accounts directly.
      allow delete: if false;

      //-- Sub-collections for Users --//

      // Transactions sub-collection for each user
      match /transactions/{transactionId} {
        // A user can only read their own transaction history.
        allow read: if isOwner(userId);
        // Transactions are immutable and created by the backend.
        allow write: if false;
      }

      // Referrals sub-collection for each user
      match /referrals/{referralId} {
         // A user can read their own referral list.
        allow read: if isOwner(userId);
        // Referrals are created by the backend.
        allow write: if false;
      }
    }

    //----------------------------------------------------------------------
    // MATCHES
    //----------------------------------------------------------------------
    match /matches/{matchId} {
        // Any signed-in user can view matches.
        allow read: if isSignedIn();
        // Users can create matches.
        allow create: if isSignedIn();
        // Users can update matches (e.g., join, submit results).
        // More specific rules can be added here for security.
        allow update: if isSignedIn();
        // Matches should be archived, not deleted.
        allow delete: if false;
    }

    //----------------------------------------------------------------------
    // KYC REQUESTS
    //----------------------------------------------------------------------
    match /kyc_requests/{requestId} {
        // Users can read their own requests. Admins can read all.
        allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
        // A user can create a KYC request for themselves.
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        // Only admins can update (approve/reject) a request.
        allow update: if isAdmin();
        // Maintain audit history.
        allow delete: if false;
    }

    //----------------------------------------------------------------------
    // DEPOSIT & WITHDRAWAL REQUESTS
    //----------------------------------------------------------------------
    match /deposit_requests/{requestId} {
      // A user can only read their own requests. Admins can read all.
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      // A user can create a deposit request for themselves.
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      // Only admins can update a request (to approve/reject it).
      allow update: if isAdmin();
      // Maintain audit history.
      allow delete: if false;
    }

    match /withdrawal_requests/{requestId} {
      // A user can only read their own requests. Admins can read all.
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      // A user can create a withdrawal request for themselves.
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      // Only admins can update a request.
      allow update: if isAdmin();
      // Maintain audit history.
      allow delete: if false;
    }
    
    //----------------------------------------------------------------------
    // TRANSACTIONS (Root Collection for Admin)
    //----------------------------------------------------------------------
    match /transactions/{transactionId} {
        // Only admins can read the global transaction list.
        allow read: if isAdmin();
        // Transactions are immutable and created by the backend.
        allow write: if false;
    }

    //----------------------------------------------------------------------
    // GLOBAL SETTINGS
    //----------------------------------------------------------------------
    match /settings/{settingId} {
      // Only admins can read or write settings.
      allow read, write: if isAdmin();
    }
  }
}
