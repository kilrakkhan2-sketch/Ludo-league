rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // You can expand this with roles (e.g., in custom claims)
    function isAdmin() {
      // In a real app, you'd check for an admin custom claim.
      // e.g., return request.auth.token.admin == true;
      return isSignedIn(); // Placeholder: for now, any signed-in user is an "admin" for testing
    }

    //----------------------------------------------------------------------
    // USER PROFILES
    //----------------------------------------------------------------------
    match /users/{userId} {
      // Admins can read and list all users.
      allow read: if isAdmin();
      
      // Users can only read their own profile, but not list others.
      allow get: if isOwner(userId);

      // Anyone can create their own user profile upon signup
      allow create: if isSignedIn();

      // Users can only update their own profile. Admins can update any (e.g., for blocking).
      allow update: if isOwner(userId) || isAdmin();

      // Users should not be able to delete their own accounts directly.
      allow delete: if false;
    }

    //----------------------------------------------------------------------
    // DEPOSIT REQUESTS
    //----------------------------------------------------------------------
    match /deposit_requests/{requestId} {
      // A user can only read their own deposit requests. Admins can read all.
      allow read, list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);

      // Any signed-in user can create a deposit request for themselves.
      // We ensure the userId in the document matches the authenticated user.
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;

      // Only admins can update a request (to approve/reject it).
      allow update: if isAdmin();
      
      // Nobody can delete deposit requests to maintain audit history.
      allow delete: if false;
    }

    //----------------------------------------------------------------------
    // WALLET TRANSACTIONS (AUDIT TRAIL)
    //----------------------------------------------------------------------
    match /wallet_transactions/{txnId} {
      // A user can only read their own transaction history. Admins can read all.
      allow read, list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);

      // Transactions should only be created by the backend (Cloud Functions).
      // Client-side creation is disallowed to prevent tampering.
      allow create: if false;

      // Transactions are immutable and cannot be changed or deleted.
      allow update, delete: if false;
    }
    
    //----------------------------------------------------------------------
    // SETTINGS
    //----------------------------------------------------------------------
    match /settings/{settingId} {
      // Only admins can read or write settings.
      allow read, write: if isAdmin();
    }
  }
}
