rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // This is less secure as it requires an extra read. Use token claims in production.
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isAdmin() {
      return getRole() in ['superadmin', 'deposit_admin', 'withdrawal_admin', 'match_admin'];
    }

    function isSuperAdmin() {
      return getRole() == 'superadmin';
    }

    //----------------------------------------------------------------------
    // USER PROFILES
    //----------------------------------------------------------------------
    match /users/{userId} {
      // Anyone can create their own user profile upon signup
      allow create: if isSignedIn();

      // Users can only read their own profile. Admins can read any profile.
      allow read: if isOwner(userId) || isAdmin();

      // Users can only update their own profile. Admins can update any (e.g., for blocking).
      allow update: if isOwner(userId) || isAdmin();

      // Users should not be able to delete their own accounts directly.
      allow delete: if false;

        // Sub-collections for user-specific data
        match /transactions/{transactionId} {
            // A user can only read their own transaction history. Admins can read all.
            allow read, list: if isOwner(userId) || isAdmin();
            // Transactions should only be created by the backend (Cloud Functions).
            allow create: if false;
            // Transactions are immutable.
            allow update, delete: if false;
        }
    }

    //----------------------------------------------------------------------
    // DEPOSIT REQUESTS
    //----------------------------------------------------------------------
    match /deposit_requests/{requestId} {
      // A user can read their own deposit requests. Deposit admins and superadmins can read all.
      allow read, list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);

      // Any signed-in user can create a deposit request for themselves.
      // We ensure the userId in the document matches the authenticated user.
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;

      // Only admins with appropriate roles can update (approve/reject). Cloud function handles the logic.
      allow update: if isAdmin();
      
      // Nobody can delete deposit requests to maintain audit history.
      allow delete: if false;
    }
  }
}
