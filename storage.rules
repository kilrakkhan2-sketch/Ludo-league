rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // HELPER FUNCTIONS -------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function getRole() {
      return request.auth.token.role;
    }
    
    function isSuperAdmin() {
      return getRole() == 'superadmin';
    }

    function isMatchAdmin() {
      return getRole() in ['superadmin', 'match_admin'];
    }
    
    function isDepositAdmin() {
      return getRole() in ['superadmin', 'deposit_admin'];
    }

    // PUBLIC & ADMIN-WRITABLE ------------------------------------
    match /appImages/{allPaths=**} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /tournament-banners/{fileName} {
      allow read: if true;
      allow write: if isMatchAdmin();
    }
    
    // USER-OWNED CONTENT -----------------------------------------
    match /avatars/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    match /deposit-screenshots/{userId}/{fileName} {
      allow read: if isOwner(userId) || isDepositAdmin();
      allow write: if isOwner(userId);
    }

    match /kyc-documents/{userId}/{fileName} {
      allow read: if isOwner(userId) || isSuperAdmin();
      allow write: if isOwner(userId);
    }

    // MATCH-SPECIFIC CONTENT -------------------------------------
    match /match-results/{matchId}/{userId}/{fileName} {
      // Any signed-in user can read (e.g. admins viewing proof)
      allow read: if isSignedIn();
      // Only the user who is submitting the result for themselves can write.
      allow write: if isOwner(userId);
    }
  }
}
