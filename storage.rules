
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isAdmin() {
      return request.auth.token.role in ['superadmin', 'match_admin', 'deposit_admin', 'withdrawal_admin'];
    }

    match /appImages/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Changed from profile-pictures to avatars for consistency
    match /avatars/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    match /deposit-screenshots/{userId}/{fileName} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);
    }

    match /kyc-documents/{userId}/{fileName} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);
    }

    // Corrected and simplified rule for match results
    match /match-results/{matchId}/{userId}/{fileName} {
      allow read: if isSignedIn();
      // Allow write if the user is authenticated and their UID matches the {userId} wildcard in the path.
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /tournament-banners/{fileName} {
      allow read: if true;
      allow write: if request.auth.token.role == 'superadmin' || request.auth.token.role == 'match_admin';
    }
  }
}
