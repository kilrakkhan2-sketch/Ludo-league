rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Check if the user has an admin role
    function isAdmin() {
      return request.auth.token.role in ['superadmin', 'match_admin', 'deposit_admin', 'withdrawal_admin'];
    }

    match /profile-pictures/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    match /deposit-screenshots/{userId}/{fileName} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);
    }

    match /kyc-documents/{userId}/{fileName} {
      allow read: if isOwner(userId) || request.auth.token.role == 'superadmin';
      allow write: if isOwner(userId);
    }

    match /match-results/{matchId}/{fileName} {
      // Only signed in users can read screenshots (e.g. admins viewing results)
      allow read: if isSignedIn();
      // A user can only write a result screenshot if their UID is in the filename.
      // This is a common pattern to ensure users can only upload files to their "own" path.
      allow write: if isSignedIn() && request.auth.uid in fileName;
    }

    match /tournament-banners/{fileName} {
      allow read: if true;
      allow write: if request.auth.token.role == 'superadmin' || request.auth.token.role == 'match_admin';
    }
  }
}
