
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Check if the user has an admin role
    function isAdmin() {
      return request.auth.token.role in ['superadmin', 'match_admin', 'deposit_admin', 'withdrawal_admin'];
    }

    match /appImages/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /profile-pictures/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    match /deposit-screenshots/{userId}/{fileName} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);
    }

    match /kyc-documents/{userId}/{fileName} {
      allow read: if isOwner(userId) || request.auth.token.role == 'superadmin';
      allow write: if isOwner(userId);
    }

    match /match-results/{matchId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && get(/databases/$(database)/documents/matches/$(matchId)).data.players.hasAny([request.auth.uid]);
    }

    match /tournament-banners/{fileName} {
      allow read: if true;
      allow write: if request.auth.token.role == 'superadmin' || request.auth.token.role == 'match_admin';
    }
  }
}

    