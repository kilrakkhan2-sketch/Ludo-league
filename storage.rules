rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    match /profile-pictures/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    match /deposit-screenshots/{userId}/{allPaths=**} {
      // TEMPORARY: Replaced rule that used get()
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    match /kyc-documents/{userId}/{allPaths=**} {
      // TEMPORARY: Replaced rule that used get()
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    match /match-results/{matchId}/{fileName} {
      allow read: if isSignedIn();
      // TEMPORARY FIX: Allow any signed-in user to upload match results.
      // This is less secure but will fix the immediate error.
      // The previous rule was invalid because get() cannot be used in storage rules.
      allow write: if isSignedIn();
    }

    match /tournament-banners/{fileName} {
      allow read: if true;
       // TEMPORARY: Replaced rule that used get()
      allow write: if isSignedIn();
    }
  }
}