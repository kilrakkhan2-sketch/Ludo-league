
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isAdmin() {
      return request.auth.token.role in ['superadmin', 'match_admin', 'deposit_admin', 'withdrawal_admin'];
    }

    match /appImages/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /profile-pictures/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    match /deposit-screenshots/{userId}/{fileName} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);
    }

    match /kyc-documents/{userId}/{fileName} {
      allow read: if isOwner(userId) || isAdmin(); // Allow owner and admins to read
      allow write: if isOwner(userId);
    }

    // FIX: Corrected path and replaced invalid `get()` call.
    match /results/{matchId}/{fileName} {
      allow read: if isSignedIn();
      // Allow write if the user is authenticated and the filename (without extension) matches their own UID.
      // This securely ensures that a player can only submit a result for themselves.
      allow write: if isSignedIn() && request.auth.uid == fileName.split('.')[0];
    }

    match /tournament-banners/{fileName} {
      allow read: if true;
      allow write: if request.auth.token.role == 'superadmin' || request.auth.token.role == 'match_admin';
    }
  }
}
